# 数据库配置（SQLAlchemy 连接字符串，默认 SQLite，换数据库只需改这里）
DATABASE_URL=sqlite+aiosqlite:///./maj_game.db

# 应用配置
SECRET_KEY=your-secret-key-here
API_V1_STR=/api/v1
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# 游戏配置
MAX_PLAYERS_PER_ROOM=4
ROOM_CODE_LENGTH=6

# 网站信息
APP_NAME=Online Multiplayer Game
APP_DESCRIPTION=FastAPI backend for online multiplayer game
APP_VERSION=1.0.0
